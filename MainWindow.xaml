<Window x:Class="SVMKurs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SVMKurs.Views"
        Title="Классификация фигур - Linear SVM" 
        Height="750" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="10" Margin="0,0,0,10">
            <TextBlock Text="Классификация фигур с помощью Linear SVM" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Управление данными">
                <views:DataManagementView DataContext="{Binding DataManagementViewModel}" Loaded="DataManagementView_Loaded"/>
            </TabItem>
            <TabItem Header="Мой SVM">
                <views:MySvmView DataContext="{Binding MySvmViewModel}" Height="626"/>
            </TabItem>
            <TabItem Header="Accord SVM">
                <views:AccordSvmView DataContext="{Binding AccordSvmViewModel}" Height="629"/>
            </TabItem>
            <TabItem Header="Сравнение">
                <views:CompareView DataContext="{Binding CompareViewModel}"/>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2" Margin="0,5,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding GlobalStatus}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>