<Window x:Class="SvmDemo.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Linear SVM - Демонстрация алгоритма классификации" 
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="184*"/>
            <ColumnDefinition Width="27*"/>
            <ColumnDefinition Width="249*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель - визуализация -->
        <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="8" 
                Background="White" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Графическое представление классификации" 
                           FontWeight="Bold" Padding="10" Background="#F0F0F0"/>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Canvas x:Name="CanvasPlot" 
                            Width="500" Height="500" 
                            Background="White"
                            ClipToBounds="True"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Правая панель - вычисления -->
        <Grid Grid.Column="1" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Панель управления -->
            <Border Grid.Row="0" Background="#2C3E50" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Linear SVM Classifier" 
                               FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Демонстрация работы алгоритма" 
                               FontSize="12" Foreground="#BDC3C7"/>
                </StackPanel>
            </Border>

            <!-- Обучающие данные -->
            <Border Grid.Row="1" Background="#F5F5F5" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="📊 Обучающие данные" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="🎓 Обучить SVM" 
                                Command="{Binding TrainCommand}"
                                Width="120" Height="35" Margin="0,0,10,0"
                                Background="#27AE60" Foreground="White"
                                BorderThickness="0" Cursor="Hand"/>
                        <Button Content="🔄 Сброс" 
                                Command="{Binding ResetCommand}"
                                Width="80" Height="35"
                                Background="#E74C3C" Foreground="White"
                                BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>

                    <ListBox Grid.Row="2" ItemsSource="{Binding TrainingSamples}" 
                             SelectedItem="{Binding SelectedSample}"
                             Height="150">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <Border Width="30" Height="30" CornerRadius="15"
                                            Background="{Binding TrueClass, Converter={StaticResource ClassToBrush}}"
                                            Margin="0,0,10,0"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock FontSize="10" Foreground="Gray">
                                            <Run Text="X₁="/><Run Text="{Binding Feature1}"/>
                                            <Run Text=" X₂="/><Run Text="{Binding Feature2}"/>
                                            <Run Text=" → "/><Run Text="{Binding ClassName}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Результат классификации с вычислениями -->
            <Border Grid.Row="2" Background="#F5F5F5" CornerRadius="8" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="🔬 Классификация тестового образца" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <!-- Ввод тестовых данных -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="X₁ (толщина):" Width="80" VerticalAlignment="Center"/>
                        <Slider Minimum="0" Maximum="10" Width="150" 
                                Value="{Binding TestFeature1}" 
                                TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                        <TextBlock Text="{Binding TestFeature1, StringFormat=F1}" Width="40" Margin="10,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="X₂ (наклон):" Width="80" VerticalAlignment="Center"/>
                        <Slider Minimum="0" Maximum="10" Width="150" 
                                Value="{Binding TestFeature2}" 
                                TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                        <TextBlock Text="{Binding TestFeature2, StringFormat=F1}" Width="40" Margin="10,0"/>
                    </StackPanel>

                    <!-- Результат -->
                    <Border Grid.Row="3" Background="White" CornerRadius="4" Padding="10">
                        <StackPanel>
                            <TextBlock Text="РЕЗУЛЬТАТ:" FontWeight="Bold" FontSize="12" Foreground="Gray"/>
                            <TextBlock Text="{Binding ClassificationResult}" 
                                       FontSize="16" FontWeight="Bold" Margin="0,5,0,10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#2C3E50"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ClassificationResult.PredictedClass}" Value="1">
                                                <Setter Property="Foreground" Value="#27AE60"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ClassificationResult.PredictedClass}" Value="-1">
                                                <Setter Property="Foreground" Value="#E74C3C"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Text="ПОШАГОВЫЕ ВЫЧИСЛЕНИЯ:" FontWeight="Bold" FontSize="12" Foreground="Gray" Margin="0,10,0,5"/>
                            <ItemsControl ItemsSource="{Binding ClassificationResult.CalculationSteps}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="5">
                                            <StackPanel>
                                                <TextBlock FontWeight="Bold" FontSize="11">
                                                    <Run Text="Шаг "/><Run Text="{Binding StepNumber}"/>: 
                                                    <Run Text="{Binding Description}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="10" Foreground="Gray" 
                                                           Text="{Binding Formula}" Margin="15,2,0,0"/>
                                                <TextBlock FontSize="10" FontWeight="Bold">
                                                    <Run Text="= "/><Run Text="{Binding Result, StringFormat=F3}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="9" Foreground="DarkGray" 
                                                           Text="{Binding Explanation}" Margin="15,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{Binding ClassificationResult.GraphPosition}" 
                                       FontSize="10" Foreground="Gray" Margin="0,10,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>