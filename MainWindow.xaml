<Window x:Class="SVMKurs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Классификация фигур с помощью Linear SVM" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <TextBlock Text="Классификация фигур - Linear SVM" 
                       FontSize="16" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - список классов и изображений -->
            <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Классы -->
                    <Border Grid.Row="0" Background="#F5F5F5" Padding="5">
                        <StackPanel>
                            <TextBlock Text="Классы фигур" FontWeight="Bold" Margin="5"/>
                            <ListBox ItemsSource="{Binding ShapeClasses}" 
                                     SelectedItem="{Binding SelectedClass}"
                                     Height="120">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                            <TextBlock Text=" (" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Images.Count}" Foreground="Gray"/>
                                            <TextBlock Text=" фото)" Foreground="Gray"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <!-- Изображения выбранного класса -->
                    <Border Grid.Row="1" Background="#FAFAFA" Padding="5">
                        <StackPanel>
                            <TextBlock Text="Изображения" FontWeight="Bold" Margin="5"/>
                            <ListBox ItemsSource="{Binding SelectedClass.Images}" 
                                     SelectedItem="{Binding SelectedImage}"
                                     Height="250">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <TextBlock Text="{Binding FileName}" Width="150"/>
                                            <TextBlock Text=" [" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Feature1, StringFormat={}{0:F2}}" Foreground="Gray"/>
                                            <TextBlock Text=", " Foreground="Gray"/>
                                            <TextBlock Text="{Binding Feature2, StringFormat={}{0:F2}}" Foreground="Gray"/>
                                            <TextBlock Text=", " Foreground="Gray"/>
                                            <TextBlock Text="{Binding Feature3, StringFormat={}{0:F2}}" Foreground="Gray"/>
                                            <TextBlock Text="]" Foreground="Gray"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки управления классами -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5">
                        <Button Content="➕ Добавить класс" Command="{Binding AddClassCommand}" Width="120" Margin="2"/>
                        <Button Content="❌ Удалить класс" Command="{Binding DeleteClassCommand}" Width="120" Margin="2"/>
                        <Button Content="📁 Добавить фото" Command="{Binding AddImagesCommand}" Width="120" Margin="2"/>
                        <Button Content="🗑 Удалить фото" Command="{Binding DeleteImageCommand}" Width="120" Margin="2"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Правая панель - обучение и результаты -->
            <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="8" Padding="10">
                <StackPanel>
                    <TextBlock Text="Обучение" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Button Content="🎓 Обучить мой SVM" 
                            Command="{Binding TrainMySvmCommand}"
                            Background="#27AE60" Foreground="White"
                            Padding="10" Margin="0,5" FontWeight="Bold"/>

                    <Button Content="📊 Обучить Accord SVM" 
                            Background="#3498DB" Foreground="White"
                            Padding="10" Margin="0,5" FontWeight="Bold"
                            IsEnabled="False"/>

                    <Border Background="#F0F0F0" CornerRadius="5" Padding="10" Margin="0,10">
                        <StackPanel>
                            <TextBlock Text="Метрики (мой SVM)" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding MySvmMetrics}" TextWrapping="Wrap"/>
                            <TextBlock Text="Статус: " Margin="0,5,0,0"/>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="Gray" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#E8F4FD" CornerRadius="5" Padding="10" Margin="0,10">
                        <StackPanel>
                            <TextBlock Text="Информация" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="1. Создайте классы (Круг, Квадрат и т.д.)" FontSize="11"/>
                            <TextBlock Text="2. Добавьте фото в каждый класс" FontSize="11"/>
                            <TextBlock Text="3. Нажмите 'Обучить мой SVM'" FontSize="11"/>
                            <TextBlock Text="4. Признаки сохраняются в JSON" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <Button Content="💾 Сохранить данные" Command="{Binding SaveDataCommand}" Width="150" Margin="2"/>
                        <Button Content="📂 Загрузить данные" Command="{Binding LoadDataCommand}" Width="150" Margin="2"/>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" FontSize="10" Foreground="Gray" TextWrapping="Wrap" Margin="0,10"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Статус бар -->
        <StatusBar Grid.Row="2" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="Готов к работе"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>