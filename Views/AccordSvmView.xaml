<UserControl x:Class="SVMKurs.Views.AccordSvmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Размер выборки -->
        <Border Grid.Row="0" BorderBrush="#CCCCCC" BorderThickness="1" Background="#FAFAFA" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Размер выборки" FontWeight="Bold" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="ОБУЧЕНИЕ" Foreground="#27AE60" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Slider Grid.Column="1" Width="200" Minimum="0" Maximum="100" Value="{Binding TrainPercentage}" 
                            TickFrequency="1" IsSnapToTickEnabled="True" Margin="10,0"/>
                    <TextBlock Grid.Column="2" Text="ТЕСТ" Foreground="#E74C3C" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Grid>

                <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center">
                    <Run Text="Обучающих: "/><Run Text="{Binding TrainCount}" Foreground="#27AE60" FontWeight="Bold"/>
                    <Run Text=" / Тестовых: "/><Run Text="{Binding TestCount}" Foreground="#E74C3C" FontWeight="Bold"/>
                    <Run Text=" (всего: "/><Run Text="{Binding TotalCount}"/><Run Text=")"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Параметры алгоритма -->
        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" Background="#FAFAFA" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Параметры алгоритма" FontWeight="Bold" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="C (регуляризация):" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding Config.C}" Width="80" HorizontalAlignment="Left"/>
                </Grid>

                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Тип зазора (Margin):" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding MarginTypes}" 
                              SelectedItem="{Binding Config.MarginType}" Width="120" HorizontalAlignment="Left"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Функция потерь (Loss):" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding LossFunctions}" 
                              SelectedItem="{Binding Config.LossFunction}" Width="120" HorizontalAlignment="Left"/>
                </Grid>

                <Button Content="Обучить" Command="{Binding TrainCommand}" 
                        Margin="0,15,0,0" Padding="10" Background="#3498DB" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" Width="150"/>
            </StackPanel>
        </Border>

        <!-- ROC и метрики -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" Background="White" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="ROC-кривая" FontWeight="Bold" Margin="10,8,0,5"/>
                    <Canvas x:Name="RocCanvas" Height="250" Margin="10" Background="White"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1" Background="#FAFAFA">
                <StackPanel Margin="12">
                    <TextBlock Text="Метрики" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <Border Background="#27AE60" Padding="10" Margin="0,0,0,8" CornerRadius="5">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Accuracy" Foreground="White" FontSize="11"/>
                            <TextBlock Text="{Binding Accuracy, StringFormat={}{0:P1}}" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#3498DB" Padding="10" Margin="0,0,0,8" CornerRadius="5">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Precision" Foreground="White" FontSize="11"/>
                            <TextBlock Text="{Binding Precision, StringFormat={}{0:P1}}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#3498DB" Padding="10" Margin="0,0,0,8" CornerRadius="5">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Recall" Foreground="White" FontSize="11"/>
                            <TextBlock Text="{Binding Recall, StringFormat={}{0:P1}}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#9B59B6" Padding="10" Margin="0,0,0,8" CornerRadius="5">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="F1 Score" Foreground="White" FontSize="11"/>
                            <TextBlock Text="{Binding F1Score, StringFormat={}{0:P1}}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Статус" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>