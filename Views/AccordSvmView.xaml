<UserControl x:Class="SVMKurs.Views.AccordSvmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Параметры алгоритма -->
        <Border Grid.Row="0" BorderBrush="#3498DB" BorderThickness="2" Background="#F0F8FF"
                Padding="12" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Параметры алгоритма" FontWeight="Bold" FontSize="15"
                           Foreground="#3498DB" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- C -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <TextBlock Text="C:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Text="{Binding Config.C}" Width="60" Height="25"/>
                    </StackPanel>

                    <!-- Loss -->
                    <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="0,0,20,0">
                        <TextBlock Text="Loss:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox ItemsSource="{Binding LossFunctions}" 
                                  SelectedItem="{Binding Config.LossFunction}" 
                                  Width="120" Height="25"/>
                    </StackPanel>

                    <!-- Tolerance -->
                    <StackPanel Orientation="Horizontal" Grid.Column="2" Margin="0,0,20,0">
                        <TextBlock Text="Tolerance:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Text="{Binding Config.Tolerance}" Width="80" Height="25"/>
                    </StackPanel>

                    <!-- Train -->
                    <Button Grid.Column="3" Content="Обучить" Command="{Binding TrainCommand}"
                            Background="#3498DB" Foreground="White" FontWeight="Bold"
                            Width="120" Height="35"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Размер выборки -->
        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" Background="#FAFAFA"
                Padding="12" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Размер выборки" FontWeight="Bold" FontSize="15" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="ОБУЧЕНИЕ" Foreground="#3498DB" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Slider Grid.Column="1" Width="200" Minimum="0" Maximum="100" Value="{Binding TrainPercentage}"
                            TickFrequency="1" IsSnapToTickEnabled="True" Margin="10,0"/>
                    <TextBlock Grid.Column="2" Text="ТЕСТ" Foreground="#E74C3C" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Grid>

                <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center">
                    <Run Text="Обучающих: "/>
                    <Run Text="{Binding TrainCount}" Foreground="#3498DB" FontWeight="Bold"/>
                    <Run Text=" / Тестовых: "/>
                    <Run Text="{Binding TestCount}" Foreground="#E74C3C" FontWeight="Bold"/>
                    <Run Text=" (всего: "/>
                    <Run Text="{Binding TotalCount}"/>
                    <Run Text=")"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ROC + Метрики -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#3498DB" BorderThickness="1" Background="White"
                    CornerRadius="5" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="ROC-кривая" FontWeight="Bold" FontSize="15"
                               Margin="10,8,0,5" Foreground="#3498DB"/>
                    <oxy:PlotView Model="{Binding RocPlotModel}" Height="300" Margin="10"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1" Background="#FAFAFA"
                    CornerRadius="5">
                <StackPanel Margin="10">
                    <TextBlock Text="Метрики" FontWeight="Bold" FontSize="15"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding Accuracy, StringFormat=Accuracy: {0:P2}}" FontSize="14"/>
                    <TextBlock Text="{Binding Precision, StringFormat=Precision: {0:P2}}" FontSize="14"/>
                    <TextBlock Text="{Binding Recall, StringFormat=Recall: {0:P2}}" FontSize="14"/>
                    <TextBlock Text="{Binding F1Score, StringFormat=F1 Score: {0:P2}}" FontSize="14"/>
                    <TextBlock Text="{Binding MacroAuc, StringFormat=AUC: {0:F3}}" FontSize="14"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="Gray" FontSize="11"
                               TextWrapping="Wrap" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>