<UserControl x:Class="SVMKurs.Views.DataManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: классы и фото -->
        <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" Background="#FAFAFA" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F5F5F5" Padding="5">
                    <StackPanel>
                        <TextBlock Text="Классы фигур" FontWeight="Bold" Margin="5"/>
                        <ListBox ItemsSource="{Binding ShapeClasses}" 
                                 SelectedItem="{Binding SelectedClass}" Height="120">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock Text=" (" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Images.Count}" Foreground="Gray"/>
                                        <TextBlock Text=" фото)" Foreground="Gray"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="White" Padding="5">
                    <StackPanel>
                        <TextBlock Text="Изображения" FontWeight="Bold" Margin="5"/>
                        <ListBox ItemsSource="{Binding SelectedClass.Images}" 
                                 SelectedItem="{Binding SelectedImage}" Height="350">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="2">
                                        <TextBlock Text="{Binding FileName}" Width="150"/>
                                        <TextBlock Text="[" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Feature1, StringFormat={}{0:F2}}" Foreground="Gray"/>
                                        <TextBlock Text=", " Foreground="Gray"/>
                                        <TextBlock Text="{Binding Feature2, StringFormat={}{0:F2}}" Foreground="Gray"/>
                                        <TextBlock Text=", " Foreground="Gray"/>
                                        <TextBlock Text="{Binding Feature3, StringFormat={}{0:F2}}" Foreground="Gray"/>
                                        <TextBlock Text="]" Foreground="Gray"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <WrapPanel Grid.Row="2" Margin="5" HorizontalAlignment="Center">
                    <Button Content="Добавить класс" Command="{Binding AddClassCommand}" Width="100" Margin="2" Padding="5"/>
                    <Button Content="Удалить класс" Command="{Binding DeleteClassCommand}" Width="110" Margin="2" Padding="5"/>
                    <Button Content="Добавить фото" Command="{Binding AddImagesCommand}" Width="110" Margin="2" Padding="5"/>
                    <Button Content="Удалить фото" Command="{Binding DeleteImageCommand}" Width="110" Margin="2" Padding="5"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Правая панель -->
        <StackPanel Grid.Column="1">

            <!-- Блок 1: Управление данными (JSON) -->
            <Border BorderBrush="#27AE60" BorderThickness="2" Background="#F0FFF0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="📁 УПРАВЛЕНИЕ ДАННЫМИ (JSON)" FontWeight="Bold" Margin="0,0,0,10" Foreground="#27AE60"/>
                    <Button Content="💾 Сохранить данные в JSON" Command="{Binding SaveDataCommand}" 
                            Background="#27AE60" Foreground="White" Padding="8" Margin="0,5" Height="35"/>
                    <Button Content="📂 Загрузить данные из JSON" Command="{Binding LoadDataCommand}" 
                            Background="#27AE60" Foreground="White" Padding="8" Margin="0,5" Height="35"/>
                </StackPanel>
            </Border>

            <!-- Блок 2: Сохранение моделей -->
            <Border BorderBrush="#3498DB" BorderThickness="2" Background="#F0F8FF" Padding="10" Margin="0,0,0,10" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="💾 СОХРАНЕНИЕ МОДЕЛЕЙ" FontWeight="Bold" Margin="0,0,0,10" Foreground="#3498DB"/>
                    <Button Content="Сохранить модель (мой SVM)" Command="{Binding SaveMyModelCommand}" 
                            Background="#3498DB" Foreground="White" Padding="8" Margin="0,5" Height="35"/>
                    <Button Content="Сохранить модель (Accord)" Command="{Binding SaveAccordModelCommand}" 
                            Background="#3498DB" Foreground="White" Padding="8" Margin="0,5" Height="35"/>
                </StackPanel>
            </Border>

            <!-- Блок 3: Загрузка моделей -->
            <Border BorderBrush="#9B59B6" BorderThickness="2" Background="#F5F0FF" Padding="10" Margin="0,0,0,10" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="📂 ЗАГРУЗКА МОДЕЛЕЙ" FontWeight="Bold" Margin="0,0,0,10" Foreground="#9B59B6"/>
                    <Button Content="Загрузить модель (мой SVM)" Command="{Binding LoadMyModelCommand}" 
                            Background="#9B59B6" Foreground="White" Padding="8" Margin="0,5" Height="35"/>
                    <Button Content="Загрузить модель (Accord)" Command="{Binding LoadAccordModelCommand}" 
                            Background="#9B59B6" Foreground="White" Padding="8" Margin="0,5" Height="35"/>
                </StackPanel>
            </Border>

            <!-- Окошко вывода сообщений -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" Background="#F9F9F9" Padding="10" Height="150" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="📢 СТАТУС" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ScrollViewer Height="100">
                        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="Gray"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>